    "test": "ng test --passWithNoTests",
    "test.watch": "ng test --watch",
    "test.ci": "ng test --ci --bail --passWithNoTests",
    "format:fix": "pretty-quick --staged",
    "precommit": "run-s format:fix",
    "lint": "ng lint",
    "=================BANK APP=================": "",
