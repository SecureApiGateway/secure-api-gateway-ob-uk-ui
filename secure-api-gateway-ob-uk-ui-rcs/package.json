    "serve.rcs.local": "ng serve rcs -c ui-local",
    "report.rcs": "npm run build.rcs.forgerock && webpack-bundle-analyzer dist/rcs/stats.json",
    "build.rcs.forgerock": "ng build --project=rcs --configuration=forgerock --output-path dist/forgerock --statsJson --extra-webpack-config webpack.extra.js",
    "build.rcs.themes": "secure-api-gateway-ob-uk-ui-cli buildThemes --project rcs"
