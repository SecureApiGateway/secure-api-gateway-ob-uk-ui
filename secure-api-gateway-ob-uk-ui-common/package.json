  "homepage": "https://github.com/SecureApiGateway/secure-api-gateway-ob-uk-ui/secure-api-gateway-ob-uk-ui-common#readme",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "npm run build.utils && npm run build.services && npm run build.components && npm run build.layouts && npm run build.gdpr && npm run build.pipes && npm run build.guards && npm run build.interceptors && npm run build.shared && npm run build.oidc && npm run build.authentication && npm run build.native",
    "postbuild": "node ./scripts/postbuild.js",
    "build.authentication": "ng build authentication",
    "build.components": "ng build components && ./scripts/bundleSass.js --project components",
    "build.gdpr": "ng build gdpr && ./scripts/bundleSass.js --project gdpr",
    "build.guards": "ng build guards",
    "build.interceptors": "ng build interceptors",
    "build.layouts": "ng build layouts && ./scripts/bundleSass.js --project layouts",
    "build.native": "ng build native",
    "build.oidc": "ng build oidc",
    "build.pipes": "ng build pipes",
    "build.services": "ng build services",
    "build.shared": "ng build shared",
    "build.utils": "ng build utils",
    "test": "ng test --passWithNoTests",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "format:fix": "pretty-quick --staged"
  },
