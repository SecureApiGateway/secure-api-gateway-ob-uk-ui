  "author": "forgerock.com",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  },
  "engineStrict": true,
  "publishConfig": {
    "registry": "https://maven.forgerock.org/artifactory/api/npm/npm-local/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SecureApiGateway/secure-api-gateway-ob-uk-ui.git",
    "directory": "secure-api-gateway-ob-uk-ui-common"
  },
  "bugs": {
    "url": "https://github.com/SecureApiGateway/secure-api-gateway-ob-uk-ui/issues"
