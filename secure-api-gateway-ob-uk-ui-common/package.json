    "build.pipes": "ng build pipes",
    "build.services": "ng build services",
    "build.shared": "ng build shared",
    "build.utils": "ng build utils",
    "test": "jest --passWithNoTests",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "format:fix": "pretty-quick --staged"
