{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "gdpr": {
      "root": "projects/gdpr",
      "sourceRoot": "projects/gdpr/src",
      "projectType": "library",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "extractLicenses": true,
          "options": {
            "tsConfig": "projects/gdpr/tsconfig.lib.json",
            "project": "projects/gdpr/ng-package.json"
          }
        ,          "configurations": {
            "production": {
              "tsConfig": "projects/gdpr/tsconfig.lib.prod.json"
            }
          }
},
        "test": {
          "builder": "@angular-builders/jest:run",
          "options": {
            "no-cache": true,
            "reporters": ["default"]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/gdpr/**/*.ts",
              "projects/gdpr/**/*.html"
            ]
          }
        }
      }
    },
